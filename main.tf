############################################
# SSH key pair (generated by Terraform)
############################################

resource "tls_private_key" "ssh" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "this" {
  key_name   = "${var.project_name}-key"
  public_key = tls_private_key.ssh.public_key_openssh
}

resource "local_file" "private_key" {
  content         = tls_private_key.ssh.private_key_pem
  filename        = "${path.module}/${var.project_name}-key.pem"
  file_permission = "0600"
}

############################################
# Default VPC / subnet (kept simple on purpose)
############################################

data "aws_vpc" "default" {
  default = true
}

data "aws_subnets" "default" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.default.id]
  }
}

############################################
# Ubuntu 22.04 AMI (Canonical)
############################################

data "aws_ami" "ubuntu" {
  most_recent = true
  owners      = ["099720109477"] # Canonical

  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-server-*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

############################################
# Logging: S3 bucket for VPC Flow Logs + instance/system logs
############################################

data "aws_caller_identity" "current" {}

resource "aws_s3_bucket" "logs" {
  bucket        = "${var.project_name}-logs-${data.aws_caller_identity.current.account_id}-${var.aws_region}"
  force_destroy = true

  tags = {
    Name = "${var.project_name}-logs"
  }
}

resource "aws_s3_bucket_public_access_block" "logs" {
  bucket                  = aws_s3_bucket.logs.id
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_lifecycle_configuration" "logs" {
  bucket = aws_s3_bucket.logs.id

  rule {
    id     = "expire-old-logs"
    status = "Enabled"

    filter {}

    expiration {
      days = 90
    }
  }
}

# Bucket policy required for VPC Flow Logs to be allowed to write to S3
resource "aws_s3_bucket_policy" "logs" {
  bucket = aws_s3_bucket.logs.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "AWSLogDeliveryWrite"
        Effect    = "Allow"
        Principal = { Service = "delivery.logs.amazonaws.com" }
        Action    = "s3:PutObject"
        Resource  = "${aws_s3_bucket.logs.arn}/vpc-flow-logs/AWSLogs/${data.aws_caller_identity.current.account_id}/*"
        Condition = {
          StringEquals = {
            "s3:x-amz-acl"       = "bucket-owner-full-control"
            "aws:SourceAccount" = data.aws_caller_identity.current.account_id
          }
        }
      },
      {
        Sid       = "AWSLogDeliveryAclCheck"
        Effect    = "Allow"
        Principal = { Service = "delivery.logs.amazonaws.com" }
        Action    = "s3:GetBucketAcl"
        Resource  = aws_s3_bucket.logs.arn
        Condition = {
          StringEquals = { "aws:SourceAccount" = data.aws_caller_identity.current.account_id }
        }
      }
    ]
  })
}

# VPC Flow Logs -> S3 (all traffic in/out of the default VPC)
resource "aws_flow_log" "vpc" {
  log_destination       = "${aws_s3_bucket.logs.arn}/vpc-flow-logs"
  log_destination_type  = "s3"
  traffic_type          = "ALL"
  vpc_id                = data.aws_vpc.default.id

  depends_on = [aws_s3_bucket_policy.logs]
}

# IAM role/instance profile so master + worker EC2 instances can
# upload their own system/kubelet logs to S3 (instance-logs/ prefix)
resource "aws_iam_role" "instance_logs" {
  name = "${var.project_name}-instance-logs-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect    = "Allow"
      Principal = { Service = "ec2.amazonaws.com" }
      Action    = "sts:AssumeRole"
    }]
  })
}

resource "aws_iam_role_policy" "instance_logs" {
  name = "${var.project_name}-instance-logs-policy"
  role = aws_iam_role.instance_logs.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect   = "Allow"
      Action   = ["s3:PutObject"]
      Resource = "${aws_s3_bucket.logs.arn}/instance-logs/*"
    }]
  })
}

resource "aws_iam_instance_profile" "instance_logs" {
  name = "${var.project_name}-instance-logs-profile"
  role = aws_iam_role.instance_logs.name
}

############################################
# Security group shared by master + worker
############################################

resource "aws_security_group" "k8s" {
  name        = "${var.project_name}-sg"
  description = "Kubernetes cluster nodes (kubeadm)"
  vpc_id      = data.aws_vpc.default.id

  # SSH
  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = [var.allowed_ssh_cidr]
  }

  # kube-apiserver
  ingress {
    description = "Kubernetes API server"
    from_port   = 6443
    to_port     = 6443
    protocol    = "tcp"
    cidr_blocks = [var.allowed_ssh_cidr]
  }

  # NodePort services, exposed externally for convenience
  ingress {
    description = "NodePort range"
    from_port   = 30000
    to_port     = 32767
    protocol    = "tcp"
    cidr_blocks = [var.allowed_ssh_cidr]
  }

  # All traffic between cluster nodes themselves: etcd, kubelet, scheduler,
  # controller-manager, Calico BGP/VXLAN, etc.
  ingress {
    description = "Intra-cluster traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    self        = true
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.project_name}-sg"
  }
}

############################################
# Master node
############################################

resource "aws_instance" "master" {
  ami                    = data.aws_ami.ubuntu.id
  instance_type          = var.instance_type
  key_name               = aws_key_pair.this.key_name
  subnet_id              = data.aws_subnets.default.ids[0]
  vpc_security_group_ids = [aws_security_group.k8s.id]
  iam_instance_profile   = aws_iam_instance_profile.instance_logs.name

  root_block_device {
    volume_size = var.root_volume_size
    volume_type = "gp3"
  }

  metadata_options {
    http_tokens   = "optional"
    http_endpoint = "enabled"
  }

  user_data = templatefile("${path.module}/scripts/master-init.sh.tpl", {
    kubernetes_version = var.kubernetes_version
    pod_network_cidr   = var.pod_network_cidr
    calico_version     = var.calico_version
    logs_bucket        = aws_s3_bucket.logs.bucket
    instance_role      = "master"
  })

  tags = {
    Name = "${var.project_name}-master"
    Role = "master"
  }
}

############################################
# Worker node
############################################

resource "aws_instance" "worker" {
  ami                    = data.aws_ami.ubuntu.id
  instance_type          = var.instance_type
  key_name               = aws_key_pair.this.key_name
  subnet_id              = data.aws_subnets.default.ids[0]
  vpc_security_group_ids = [aws_security_group.k8s.id]
  iam_instance_profile   = aws_iam_instance_profile.instance_logs.name

  root_block_device {
    volume_size = var.root_volume_size
    volume_type = "gp3"
  }

  metadata_options {
    http_tokens   = "optional"
    http_endpoint = "enabled"
  }

  user_data = templatefile("${path.module}/scripts/worker-init.sh.tpl", {
    kubernetes_version = var.kubernetes_version
    logs_bucket        = aws_s3_bucket.logs.bucket
    instance_role      = "worker"
  })

  tags = {
    Name = "${var.project_name}-worker"
    Role = "worker"
  }
}

############################################
# Automatically join the worker to the cluster
# Runs locally (where you run `terraform apply`), SSHes into
# both nodes with the generated key, waits for cloud-init to
# finish, then runs the kubeadm join command on the worker.
############################################

resource "null_resource" "join_cluster" {
  depends_on = [
    aws_instance.master,
    aws_instance.worker,
    local_file.private_key,
  ]

  triggers = {
    master_id = aws_instance.master.id
    worker_id = aws_instance.worker.id
  }

provisioner "local-exec" {
    interpreter = ["D:/Git/usr/bin/bash.exe", "-c"]
    command = "bash '${path.module}/scripts/join-cluster.sh' '${aws_instance.master.public_ip}' '${aws_instance.worker.public_ip}' '${local_file.private_key.filename}'"
  }
}
